# ── JWT Secrets ───────────────────────────────────────────────
JWT_SECRET=healthapi_jwt_super_secret_key_2026_change_in_prod
JWT_REFRESH_SECRET=healthapi_refresh_super_secret_key_2026_change_in_prod
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── OAuth 2.0 Token TTLs (seconds) ───────────────────────────
OAUTH_ACCESS_TOKEN_TTL=3600
OAUTH_REFRESH_TOKEN_TTL=604800
OAUTH_AUTH_CODE_TTL=300

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
# On Render this will be your public URL, e.g.:
BASE_URL=https://healthapi.onrender.com

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
